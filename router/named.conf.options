options {
    directory "/var/cache/bind";

    # Solo escucha en las interfaces internas
    listen-on { 127.0.0.1; 10.10.10.1; 10.20.20.1; 10.30.30.1; };

    # Solo responde a nuestras redes
    allow-query { localhost; 10.10.10.0/24; 10.20.20.0/24; 10.30.30.0/24; };

    # Reenvía consultas externas a Google/Cloudflare
    forwarders { 8.8.8.8; 1.1.1.1; };
    forward only;

    dnssec-validation no;
    recursion yes;
};
